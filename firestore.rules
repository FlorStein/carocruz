rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          'admin@caracruz.com.ar',
          'admin@carocruz.com.ar'
        ];
    }

    // Productos: lectura pública, escritura solo admin
    match /productos_admin/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Overrides de producto
    match /productos_overrides/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Configuración comercial
    match /config_admin/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Pedidos: solo escritura del backend (Cloud Functions con Admin SDK, bypasea reglas)
    // Lectura: admin ve todos; el comprador solo ve sus propios pedidos (por email)
    match /pedidos/{pedidoId} {
      allow read: if isAdmin() ||
        (request.auth != null &&
         request.auth.token.email != null &&
         resource.data.comprador.email == request.auth.token.email);
      allow create, update, delete: if false; // solo el backend (Admin SDK) puede escribir
    }

    // Perfiles de usuario
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
